# ==============================================
# 1. 系统级忽略（全平台通用）
# ==============================================
# macOS 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows 系统文件
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux 系统文件
*~
.fuse_hidden*
.directory
.nfs*

# ==============================================
# 2. 编辑器/IDE 忽略
# ==============================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace
.history/

# JetBrains 全家桶
.idea/
*.iml
*.iws
*.ipr
out/

# ==============================================
